LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen/qwen3-vl-4b
LM_TEMPERATURE=0.3
HF_HUB_DISABLE_SYMLINKS_WARNING=1

WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=default
WHISPER_LANGUAGE=en
WHISPER_INITIAL_PROMPT=This is clear spoken English conversation.
STT_PREPROCESS=false
STT_DENOISE_STRENGTH=0.7
STT_NOISE_FLOOR_PERCENTILE=20
STT_HIGHPASS_HZ=70
STT_NORMALIZE=true
STT_TARGET_RMS=0.08
STT_MAX_GAIN=8.0
STT_PEAK_LIMIT=0.95
REPLAY_ALL_CAPTURED_AUDIO=false
REPLAY_ALL_CAPTURED_AUDIO_MAX_SEC=5
REPLAY_ON_STT_FAIL=true
REPLAY_ON_STT_FAIL_MAX_SEC=6.0
INPUT_MODE=auto
INPUT_SAMPLE_RATE=auto
INPUT_DEVICE_NAME=
OUTPUT_DEVICE_NAME=
PUSH_TO_TALK=true
PUSH_TO_TALK_KEY=F8

KOKORO_REPO_ID=hexgrad/Kokoro-82M
KOKORO_LANG_CODE=a
KOKORO_VOICE=af_bella,af_nicole
KOKORO_SPEED=1.0
KOKORO_SPLIT_PATTERN=\n+
TTS_SIMPLE_PLAYBACK=true

SYSTEM_PROMPT=You are a real-time voice assistant with tool calling and vision capabilities. Reply in the language used by the user. Keep replies concise and practical for spoken dialogue. Use a mature neutral tone. Avoid emojis and decorative symbols. Whenever possible, keep the answer to one sentence.
